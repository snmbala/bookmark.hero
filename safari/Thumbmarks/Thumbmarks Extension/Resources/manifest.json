{
   "action": {
      "default_icon": {
         "128": "assets/icons/bookmark.png",
         "16": "assets/icons/bookmark.png",
         "48": "assets/icons/bookmark.png"
      },
      "default_popup": "main.html?mode=popover"
   },
   "background": {
      "service_worker": "background.js"
   },
   "description": "Visual bookmark manager with auto-captured thumbnails and instant search.",
   "host_permissions": [ "<all_urls>" ],
   "icons": {
      "128": "assets/icons/bookmark.png",
      "16": "assets/icons/bookmark.png",
      "48": "assets/icons/bookmark.png"
   },
   "manifest_version": 3,
   "name": "Thumbmarks – Visual Bookmark Manager",
   "permissions": [ "bookmarks", "tabs", "storage", "activeTab" ],
   "version": "1.6.3"
}