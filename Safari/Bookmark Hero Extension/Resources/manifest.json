{
   "manifest_version": 3,
   "name": "Thumbmark – Visual Bookmark Manager",
   "description": "Thumbmark is a visual bookmark manager that shows bookmarks with page previews and thumbnails, making it easier to organize and search saved websites.",
   "version": "1.5.0",
   "icons": {
      "16": "assets/icons/bookmark.png",
      "48": "assets/icons/bookmark.png",
      "128": "assets/icons/bookmark.png"
   },
   "action": {
      "default_icon": {
         "16": "assets/icons/bookmark.png",
         "48": "assets/icons/bookmark.png",
         "128": "assets/icons/bookmark.png"
      }
   },
   "background": {
      "scripts": [ "background.js" ],
      "type": "module"
   },
   "permissions": [ "bookmarks", "tabs", "storage", "activeTab" ],
   "host_permissions": [ "<all_urls>" ]
}
