{
  "name": "thumbmark",
  "version": "1.6.0",
  "description": "Visual bookmark manager for Chrome - auto-captured thumbnails, smart search, keyboard shortcuts",
  "type": "module",
  "main": "background.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/snmbala/thumbmark"
  },
  "author": "Balamurugan",
  "license": "MIT",
  "scripts": {
    "build:css": "npx tailwindcss -i ./css/input.css -o ./dist/css/styles.css --minify",
    "build": "npm run build:css && vite build",
    "build:safari": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && cd dist && zip -r ../thumbmark-dist.zip . && cd .. && echo '✅ Package created: thumbmark-dist.zip'"
  },
  "keywords": ["bookmarks", "chrome-extension", "productivity", "visual", "search"],
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.2",
    "vite-plugin-static-copy": "^3.1.1",
    "vitest": "^1.2.1"
  }
}